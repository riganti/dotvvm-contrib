<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>netstandard2.1;net472</TargetFrameworks>
		<PackageId>DotVVM.Contrib.Humanizer</PackageId>
		<AssemblyName>DotVVM.Contrib.Humanizer</AssemblyName>
		<Description>The Humanizer control library for DotVVM. Provides the HumanizeDateTime control and JavaScript translators for Humanizer extension methods.</Description>
		<PackageTags>dotvvm;asp.net;mvvm;dotnetcore;humanizer</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<None Remove="Scripts\DotVVM.Contrib.Humanizer.js" />
		<None Remove="Scripts\dayjs\dayjs.min.js" />
		<None Remove="Scripts\dayjs\relativeTime.js" />
		<None Remove="Scripts\dayjs\locales.js" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="Scripts\DotVVM.Contrib.Humanizer.js" />
		<EmbeddedResource Include="Scripts\dayjs\dayjs.min.js" />
		<EmbeddedResource Include="Scripts\dayjs\relativeTime.js" />
		<EmbeddedResource Include="Scripts\dayjs\locales.js" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="DotVVM" Version="$(DotvvmVersion)" />
		<PackageReference Include="Humanizer.Core" Version="2.14.1" />
	</ItemGroup>

</Project>
